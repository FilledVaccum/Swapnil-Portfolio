---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import ContentHeader from '../../components/ContentHeader.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { id: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<ContentLayout title={project.data.title}>
  <ContentHeader
    title={project.data.title}
    date={project.data.date}
    tags={project.data.tags}
  />
  <div class="project-meta">
    <p><strong>Tech:</strong> {project.data.tech.join(', ')}</p>
    <div class="external-links">
      {project.data.github && <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="link-pill">GitHub</a>}
      {project.data.live && <a href={project.data.live} target="_blank" rel="noopener noreferrer" class="link-pill">Live Demo</a>}
    </div>
  </div>
  <article class="prose">
    <Content />
  </article>
</ContentLayout>

<style>
  .project-meta {
    background: var(--color-cream-light);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    margin-bottom: var(--space-xl);
  }
  .project-meta p { margin-bottom: var(--space-sm); font-size: var(--text-sm); }
  .external-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }
  .link-pill {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-cream);
    background: var(--color-clay);
    padding: 0.4em 1.2em;
    border-radius: 999px;
    text-decoration: none;
    transition: background var(--transition-fast);
  }
  .link-pill:hover {
    background: var(--color-olive);
    color: var(--color-cream);
  }
  .prose :global(h2) { margin-top: var(--space-xl); margin-bottom: var(--space-md); }
  .prose :global(p) { margin-bottom: var(--space-md); }
</style>
