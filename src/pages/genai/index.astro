---
import { getCollection } from 'astro:content';
import GridLayout from '../../layouts/GridLayout.astro';
import Card from '../../components/Card.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';

const allCategories = [
  'Pre-training',
  'Post-training',
  'Fine-tuning',
  'Inference',
  'Agentic AI',
  'RAG',
  'Prompt Engineering',
  'Evaluation',
  'Multimodal',
  'LLMOps',
];

const posts = (await getCollection('genai'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group posts by category
const postsByCategory = new Map<string, typeof posts>();
for (const cat of allCategories) {
  postsByCategory.set(cat, posts.filter(p => p.data.category === cat));
}
const uncategorized = posts.filter(p => !p.data.category || !allCategories.includes(p.data.category));
---

<GridLayout title="GenAI">
  <h1>GenAI</h1>
  <p class="section-desc">Deep dives into generative AI — from pre-training to production.</p>

  <div class="subcategories">
    {allCategories.map(cat => {
      const catPosts = postsByCategory.get(cat) || [];
      return (
        <div class="subcategory">
          <div class="subcategory-header">
            <h2 class="subcategory-title">{cat}</h2>
            <span class="subcategory-count">{catPosts.length} {catPosts.length === 1 ? 'post' : 'posts'}</span>
          </div>
          {catPosts.length > 0 ? (
            <div class="card-grid">
              {catPosts.map(post => (
                <Card
                  title={post.data.title}
                  href={`/genai/${post.id}`}
                  description={post.data.description}
                  date={post.data.date}
                  tags={post.data.tags}
                />
              ))}
            </div>
          ) : (
            <p class="empty-note">No posts yet. Check back soon.</p>
          )}
        </div>
      );
    })}
  </div>

  {uncategorized.length > 0 && (
    <div class="subcategory">
      <h2 class="subcategory-title">Other</h2>
      <div class="card-grid">
        {uncategorized.map(post => (
          <Card
            title={post.data.title}
            href={`/genai/${post.id}`}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
          />
        ))}
      </div>
    </div>
  )}
</GridLayout>

<style>
  h1 { margin-bottom: var(--space-sm); }
  .section-desc {
    color: var(--color-warm-gray);
    margin-bottom: var(--space-xl);
  }
  .subcategories {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }
  .subcategory-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-stone);
    padding-bottom: var(--space-sm);
  }
  .subcategory-title {
    font-size: var(--text-xl);
    margin: 0;
  }
  .subcategory-count {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-stone);
  }
  .empty-note {
    font-size: var(--text-sm);
    color: var(--color-stone);
    font-style: italic;
    padding: var(--space-md) 0;
  }
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-lg);
  }
</style>
