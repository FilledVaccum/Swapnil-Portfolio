---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="tag-list">
  {tags.map(tag => (
    <span class="tag">{tag}</span>
  ))}
</div>

<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .tag {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-olive);
    background: rgba(122, 139, 111, 0.1);
    padding: 0.15em 0.6em;
    border-radius: 999px;
  }
</style>
